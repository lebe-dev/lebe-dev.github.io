---
import { useTranslations } from '../i18n/utils';
import { languages, type Lang } from '../i18n/ui';

type Props = { lang: Lang };
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<select id="lang-switch" aria-label={t('lang.switch')} title={t('lang.switch')}>
  {Object.entries(languages).map(([code, name]) => (
    <option value={code} selected={code === lang}>{name}</option>
  ))}
</select>

<script is:inline>
  (() => {
    const select = document.getElementById('lang-switch');
    if (!select) return;
    select.addEventListener('change', () => {
      const value = select.value;
      try { localStorage.setItem('lang', value); } catch {}
      window.location.href = `/${value}/`;
    });
  })();
</script>
