---
---
<svg
  class="deco"
  viewBox="0 0 900 220"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label=""
  aria-hidden="true"
  preserveAspectRatio="xMidYMid meet"
>
  <defs>
    <linearGradient id="lines-grad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#6d28d9" />
      <stop offset="35%" stop-color="#be185d" />
      <stop offset="70%" stop-color="#ef4444" />
      <stop offset="100%" stop-color="#f59e0b" />
    </linearGradient>
  </defs>
  {Array.from({ length: 12 }, (_, i) => {
    const x1 = 80 + i * 22;
    const x2 = 480 + i * 30;
    const y = 210 - i * 14;
    return <line x1={x1} y1={y} x2={x2} y2={y} stroke="url(#lines-grad)" stroke-width="3" stroke-linecap="round" />;
  })}
</svg>
