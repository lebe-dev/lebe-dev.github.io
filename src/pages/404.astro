---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ui, languages } from '../i18n/ui';
---
<BaseLayout lang="en" title={ui.en['404.title']}>
  <article>
    <h1>{ui.en['404.title']} · {ui.ru['404.title']}</h1>
    <p>{ui.en['404.body']}</p>
    <p>{ui.ru['404.body']}</p>
    <p>
      {Object.entries(languages).map(([code, name], i) => (
        <>
          {i > 0 && ' · '}
          <a href={`/${code}/`}>{name}</a>
        </>
      ))}
    </p>
  </article>
</BaseLayout>
