---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DecorativeLines from '../../components/DecorativeLines.astro';
import Bio from '../../components/Bio.astro';
import ProjectsList from '../../components/ProjectsList.astro';
import PostsList from '../../components/PostsList.astro';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

export const getStaticPaths = () => [
  { params: { lang: 'en' } },
  { params: { lang: 'ru' } },
];

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const all = await getCollection('blog', (e) => e.data.lang === lang && !e.data.draft);
const posts = all
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((e) => ({
    slug: e.id.replace(/^[a-z]{2}\//, ''),
    title: e.data.title,
    pubDate: e.data.pubDate,
  }));
---
<BaseLayout lang={lang}>
  <DecorativeLines />
  <Bio lang={lang} />
  <ProjectsList lang={lang} />
  <section aria-labelledby="musings-heading">
    <h2 id="musings-heading" class="section-title">
      {t('section.musings')}
      <a class="rss" href={`/${lang}/rss.xml`} aria-label={t('rss.title')} title={t('rss.title')}>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36zM4 4.44A15.56 15.56 0 0 1 19.56 20h-2.84A12.72 12.72 0 0 0 4 7.28V4.44zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
        </svg>
      </a>
    </h2>
    <PostsList lang={lang} posts={posts} />
  </section>
</BaseLayout>
