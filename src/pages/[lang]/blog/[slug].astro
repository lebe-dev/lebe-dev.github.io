---
import { render } from 'astro:content';
import { getBlogPosts } from '../../../lib/blog';
import PostLayout from '../../../layouts/PostLayout.astro';
import type { Lang } from '../../../i18n/ui';
import { getReadingStats } from '../../../i18n/utils';
import { resolveAiUsageDisclaimer } from '../../../i18n/aiUsageDisclaimer';

export async function getStaticPaths() {
  const all = await getBlogPosts();
  const slug = (id: string) => id.replace(/^[a-z]{2}\//, '');
  return all.map((entry) => {
    const key = entry.data.translationKey;
    const translations = key
      ? all
          .filter((e) => e.data.translationKey === key)
          .map((e) => ({
            code: e.data.lang as Lang,
            url: `/${e.data.lang}/blog/${slug(e.id)}/`,
          }))
      : [];
    return {
      params: {
        lang: entry.data.lang,
        slug: slug(entry.id),
      },
      props: { entry, translations },
    };
  });
}

const { entry, translations } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);
const disclaimer = resolveAiUsageDisclaimer(lang, entry.data);
const readingStats = getReadingStats(entry.body ?? '');
---
<PostLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updated={entry.data.updated}
  chars={readingStats.chars}
  minutes={readingStats.minutes}
  markdown={entry.body ?? ''}
  translations={translations}
  aiUsageDisclaimer={disclaimer.aiUsageDisclaimer}
  aiUsageDisclaimerShowLeaveButton={disclaimer.aiUsageDisclaimerShowLeaveButton}
  aiUsageDisclaimerLeaveButtonText={disclaimer.aiUsageDisclaimerLeaveButtonText}
  aiUsageDisclaimerShowAcceptButton={disclaimer.aiUsageDisclaimerShowAcceptButton}
  aiUsageDisclaimerAcceptButtonText={disclaimer.aiUsageDisclaimerAcceptButtonText}
>
  <Content />
</PostLayout>
