---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import type { Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const all = await getCollection('blog', (e) => !e.data.draft);
  return all.map((entry) => ({
    params: {
      lang: entry.data.lang,
      slug: entry.id.replace(/^[a-z]{2}\//, ''),
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);
---
<PostLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  updated={entry.data.updated}
  disclaimer={entry.data.disclaimer}
  disclaimerShowLeaveButton={entry.data.disclaimerShowLeaveButton}
  disclaimerLeaveButtonText={entry.data.disclaimerLeaveButtonText}
>
  <Content />
</PostLayout>
