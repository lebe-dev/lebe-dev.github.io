---
import { getBlogPosts } from '../../../lib/blog';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostsList from '../../../components/PostsList.astro';
import { useTranslations } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';

export const getStaticPaths = () => [
  { params: { lang: 'en' } },
  { params: { lang: 'ru' } },
  { params: { lang: 'es' } },
  { params: { lang: 'zh' } },
  { params: { lang: 'ja' } },
  { params: { lang: 'fr' } },
  { params: { lang: 'de' } },
];

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const all = await getBlogPosts((e) => e.data.lang === lang);
const posts = all
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((e) => ({
    slug: e.id.replace(/^[a-z]{2}\//, ''),
    title: e.data.title,
    pubDate: e.data.pubDate,
  }));
---
<BaseLayout lang={lang} title={t('section.allPosts')} description={t('blog.description')}>
  <h1>{t('section.allPosts')}</h1>
  <PostsList lang={lang} posts={posts} />
</BaseLayout>
