---
// Language landing shim: static page that JS-redirects to /en/ or /ru/ based on
// localStorage.lang or navigator.language. Falls back to /en/ for crawlers and
// no-JS clients via <meta refresh> and visible links.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Eugene Lebedev</title>
    <link rel="canonical" href="https://lebe-dev.github.io/en/" />
    <link rel="alternate" hreflang="en" href="https://lebe-dev.github.io/en/" />
    <link rel="alternate" hreflang="ru" href="https://lebe-dev.github.io/ru/" />
    <link rel="alternate" hreflang="x-default" href="https://lebe-dev.github.io/en/" />
    <meta http-equiv="refresh" content="0;url=/en/" />
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('lang');
          const detected = (navigator.language || 'en').toLowerCase().startsWith('ru') ? 'ru' : 'en';
          const lang = saved === 'en' || saved === 'ru' ? saved : detected;
          window.location.replace(`/${lang}/`);
        } catch {
          window.location.replace('/en/');
        }
      })();
    </script>
    <style>
      body { font-family: system-ui, sans-serif; padding: 3rem 1.25rem; max-width: 540px; margin: 0 auto; color: #1a1a1a; }
      a { color: #2563eb; }
    </style>
  </head>
  <body>
    <noscript>
      <h1>Eugene Lebedev</h1>
      <p>Choose your language · Выберите язык:</p>
      <p><a href="/en/">English</a> · <a href="/ru/">Русский</a></p>
    </noscript>
  </body>
</html>
