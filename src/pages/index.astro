---
// Language landing shim: static page that JS-redirects to the matching locale based on
// localStorage.lang or navigator.language. Falls back to /en/ for crawlers and
// no-JS clients via <meta refresh> and visible links.
import { languages } from '../i18n/ui';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Eugene Lebedev</title>
    <meta name="description" content="Personal site & blog of Eugene Lebedev." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={new URL('/en/', Astro.site).toString()} />
    {Object.keys(languages).map((code) => (
      <link rel="alternate" hreflang={code} href={new URL(`/${code}/`, Astro.site).toString()} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/en/', Astro.site).toString()} />
    <meta http-equiv="refresh" content="0;url=/en/" />
    <script is:inline define:vars={{ langCodes: Object.keys(languages) }}>
      (() => {
        try {
          const saved = localStorage.getItem('lang');
          const browserLangs = navigator.languages || [navigator.language || 'en'];
          let detected = 'en';
          for (const bl of browserLangs) {
            const prefix = bl.toLowerCase().split('-')[0];
            if (langCodes.includes(prefix)) {
              detected = prefix;
              break;
            }
          }
          const lang = langCodes.includes(saved) ? saved : detected;
          window.location.replace(`/${lang}/`);
        } catch {
          window.location.replace('/en/');
        }
      })();
    </script>
    <style>
      body { font-family: system-ui, sans-serif; padding: 3rem 1.25rem; max-width: 540px; margin: 0 auto; color: #1a1a1a; }
      a { color: #2563eb; }
    </style>
  </head>
  <body>
    <noscript>
      <h1>Eugene Lebedev</h1>
      <p>Choose your language · Выберите язык:</p>
      <p>
        {Object.entries(languages).map(([code, name], i) => (
          <>
            {i > 0 && ' · '}
            <a href={`/${code}/`}>{name}</a>
          </>
        ))}
      </p>
    </noscript>
  </body>
</html>
