---
import BaseLayout from '../layouts/BaseLayout.astro';
import YamlValidator from '../components/YamlValidator.svelte';
---
<BaseLayout
  lang="en"
  title="YAML Validator"
  description="Paste YAML and instantly check if it's valid, right in your browser."
  minimalHeader
  resetVisited
>
  <article>
    <h1>YAML Validator</h1>
    <p class="muted">
      Paste your YAML below. It's validated as you type, entirely in your browser — nothing is sent anywhere.
    </p>
    <YamlValidator client:load />
  </article>
</BaseLayout>
