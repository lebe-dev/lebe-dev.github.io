---
import '@fontsource/merriweather/400.css';
import '@fontsource/merriweather/700.css';
import '../styles/global.css';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import { ui, languages, ogLocale } from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  showHeaderTitle?: boolean;
  minimalHeader?: boolean;
  resetVisited?: boolean;
}

const { lang, title, description, showHeaderTitle = true, minimalHeader = false, resetVisited = false } = Astro.props;
const t = useTranslations(lang);
const pageTitle = title ? `${title} — ${t('site.name')}` : t('site.name');
const pageDescription = description ?? t('site.description');
const canonical = new URL(Astro.url.pathname, Astro.site);
const otherLangs = (Object.keys(languages) as Lang[]).filter((l) => l !== lang);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="alternate" hreflang={lang} href={canonical.toString()} />
    {otherLangs.map((l) => (
      <link
        rel="alternate"
        hreflang={l}
        href={new URL(Astro.url.pathname.replace(`/${lang}/`, `/${l}/`), Astro.site).toString()}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).toString()} />
    <link rel="alternate" type="application/rss+xml" title={`${ui[lang]['rss.title']} (${lang})`} href={`/${lang}/rss.xml`} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:locale" content={ogLocale[lang]} />
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (t === 'dark' || (!t && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch {}
      })();
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5DRJHT5J');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5DRJHT5J"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header lang={lang} showTitle={showHeaderTitle} minimal={minimalHeader} />
    <main class:list={[{ 'reset-visited': resetVisited }]}>
      <slot />
    </main>
    <Footer lang={lang} />
    <script is:inline>
      (() => {
        document.querySelectorAll('a[href^="http"]').forEach((link) => {
          if (link.hostname === location.hostname) return;
          link.target = '_blank';
          const rel = new Set((link.getAttribute('rel') || '').split(/\s+/).filter(Boolean));
          rel.add('noopener');
          rel.add('noreferrer');
          link.setAttribute('rel', [...rel].join(' '));
        });
      })();
    </script>
  </body>
</html>
