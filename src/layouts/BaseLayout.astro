---
import '@fontsource/merriweather/400.css';
import '@fontsource/merriweather/700.css';
import '../styles/global.css';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';
import { ui, languages, ogLocale } from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  showHeaderTitle?: boolean;
  minimalHeader?: boolean;
  localeUrls?: Partial<Record<Lang, string>>;
}

const { lang, title, description, showHeaderTitle = true, minimalHeader = false, localeUrls } = Astro.props;
const t = useTranslations(lang);
const pageTitle = title ? `${title} — ${t('site.name')}` : t('site.name');
const pageDescription = description ?? t('site.description');
const canonical = new URL(Astro.url.pathname, Astro.site);
const otherLangs = (Object.keys(languages) as Lang[]).filter((l) => l !== lang);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <script is:inline define:vars={{ currentLang: lang, langCodes: Object.keys(languages), localeUrls: localeUrls ?? null }}>
      (() => {
        try {
          const saved = localStorage.getItem('lang');
          let target = null;
          if (saved && langCodes.includes(saved)) {
            target = saved;
          } else if (!saved) {
            const browserLangs = navigator.languages || [navigator.language || ''];
            for (const bl of browserLangs) {
              const prefix = bl.toLowerCase().split('-')[0];
              if (langCodes.includes(prefix)) { target = prefix; break; }
            }
          }
          if (!target || target === currentLang) return;

          let url;
          if (localeUrls) {
            // Page with language-specific URLs (e.g. blog posts): only redirect
            // if a translation actually exists for the target language.
            url = localeUrls[target];
            if (!url) return;
          } else {
            url = location.pathname.replace('/' + currentLang + '/', '/' + target + '/');
          }

          const dest = url + location.search + location.hash;
          if (url && url !== location.pathname) location.replace(dest);
        } catch {}
      })();
    </script>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="alternate" hreflang={lang} href={canonical.toString()} />
    {otherLangs.map((l) => (
      <link
        rel="alternate"
        hreflang={l}
        href={new URL(Astro.url.pathname.replace(`/${lang}/`, `/${l}/`), Astro.site).toString()}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).toString()} />
    <link rel="alternate" type="application/rss+xml" title={`${ui[lang]['rss.title']} (${lang})`} href={`/${lang}/rss.xml`} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:locale" content={ogLocale[lang]} />
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (t === 'dark' || (!t && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch {}
      })();
    </script>
  </head>
  <body>
    <Header lang={lang} showTitle={showHeaderTitle} minimal={minimalHeader} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
