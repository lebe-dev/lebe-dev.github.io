---
import BaseLayout from './BaseLayout.astro';
import PostLangSwitch from '../components/PostLangSwitch.svelte';
import AiUsageDisclaimer from '../components/AiUsageDisclaimer.svelte';
import { formatDate, useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  pubDate: Date;
  updated?: Date;
  chars?: number;
  minutes?: number;
  markdown?: string;
  translations?: { code: Lang; url: string }[];
  aiUsageDisclaimer?: string;
  aiUsageDisclaimerShowLeaveButton?: boolean;
  aiUsageDisclaimerLeaveButtonText?: string;
  aiUsageDisclaimerShowAcceptButton?: boolean;
  aiUsageDisclaimerAcceptButtonText?: string;
}

const {
  lang,
  title,
  description,
  pubDate,
  updated,
  chars,
  minutes,
  markdown = '',
  translations = [],
  aiUsageDisclaimer,
  aiUsageDisclaimerShowLeaveButton,
  aiUsageDisclaimerLeaveButtonText,
  aiUsageDisclaimerShowAcceptButton,
  aiUsageDisclaimerAcceptButtonText,
} = Astro.props;
const t = useTranslations(lang);
const formattedChars = typeof chars === 'number' ? chars.toLocaleString(lang) : null;
const localeUrls = Object.fromEntries(translations.map((tr) => [tr.code, tr.url]));
---
<BaseLayout lang={lang} title={title} description={description} showHeaderTitle={false} minimalHeader localeUrls={localeUrls}>
  <article>
    <h1>{title}</h1>
    <p class="post-meta">
      <span class="post-date">
        {formatDate(pubDate)}
        {updated && <> · upd. {formatDate(updated)}</>}
      </span>
      {formattedChars && typeof minutes === 'number' && (
        <>
          <span class="post-sep" aria-hidden="true">·</span>
          <span class="post-stats">
            {formattedChars} {t('post.chars')}
            <span class="post-sep post-sep--inline" aria-hidden="true">·</span>
            ~{minutes} {t('post.minRead')}
          </span>
        </>
      )}
      {(translations.length > 1 || markdown) && (
        <span class="post-actions">
          {translations.length > 1 && (
            <span class="post-lang-inline">
              <PostLangSwitch lang={lang} label={t('lang.switch')} translations={translations} client:load />
            </span>
          )}
          {markdown && (
            <button
              type="button"
              id="copy-md"
              class="copy-md"
              title={t('post.copyMd')}
              aria-label={t('post.copyMd')}
            >
              <svg class="copy-md__icon copy-md__icon--copy" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg class="copy-md__icon copy-md__icon--check" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
              <span class="copy-md__text">{t('post.copyMdShort')}</span>
            </button>
          )}
        </span>
      )}
    </p>
    {markdown && <textarea id="post-markdown" hidden readonly>{markdown}</textarea>}
    {aiUsageDisclaimer && (
      <AiUsageDisclaimer
        label={t('post.aiUsageDisclaimer')}
        text={aiUsageDisclaimer}
        showAcceptButton={aiUsageDisclaimerShowAcceptButton}
        acceptButtonText={aiUsageDisclaimerAcceptButtonText}
        showLeaveButton={aiUsageDisclaimerShowLeaveButton}
        leaveButtonText={aiUsageDisclaimerLeaveButtonText}
        client:load
      />
    )}
    <slot />
    <hr />
    <p><a href={`/${lang}/blog/`}>{t('post.backToBlog')}</a></p>
  </article>

  <div class="lightbox" id="lightbox" hidden>
    <img src="" alt="" />
  </div>
</BaseLayout>

<style>
  :global(main) {
    padding-top: 0.5rem;
  }

  article h1 {
    font-family: var(--heading-serif);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  article :global(.post-meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem 0.75rem;
  }

  .post-date,
  .post-stats,
  .post-sep {
    font-size: 0.75rem;
    opacity: 0.85;
  }

  .post-sep--inline {
    margin: 0 0.5rem;
  }

  .copy-md {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    line-height: 1;
    letter-spacing: 0.03em;
    font-family: inherit;
    font-style: normal;
    color: inherit;
    opacity: 0.9;
    padding: 0.2rem 0.45rem;
    border: none;
    border-radius: 4px;
    background: transparent;
    cursor: pointer;
    transition: opacity 0.15s ease, color 0.15s ease;
  }

  .copy-md:hover {
    opacity: 1;
  }

  :global(.dark) .copy-md {
    opacity: 0.95;
  }

  :global(.dark) .copy-md:hover {
    opacity: 1;
    color: #fff;
  }

  :global(.dark) .copy-md.is-copied {
    color: #66bb6a;
  }

  .copy-md.is-copied {
    opacity: 1;
    color: #2e7d32;
  }

  .copy-md__icon {
    flex-shrink: 0;
  }

  .copy-md__icon--check {
    display: none;
  }

  .copy-md.is-copied .copy-md__icon--copy {
    display: none;
  }

  .copy-md.is-copied .copy-md__icon--check {
    display: inline;
  }

  .post-actions {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-lang-inline {
    display: inline-flex;
    align-items: center;
  }

  .post-lang-inline :global([data-slot="select-trigger"]) {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    height: auto;
    min-height: 0;
    padding: 0.2rem 0.45rem;
    gap: 0.25rem;
  }

  article :global(h2),
  article :global(h3),
  article :global(h4) {
    font-family: var(--heading-serif);
    font-weight: 700;
  }

  article :global(img) {
    cursor: zoom-in;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.9);
    cursor: zoom-out;
    z-index: 1000;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox img {
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
  }

</style>

<script is:inline>
  (() => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = lightbox?.querySelector('img');
    if (!lightbox || !lightboxImg) return;

    document.querySelectorAll('article img').forEach((img) => {
      img.addEventListener('click', () => {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightbox.hidden = false;
      });
    });

    const close = () => {
      lightbox.hidden = true;
      lightboxImg.src = '';
    };

    lightbox.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox.hidden) close();
    });
  })();

  (() => {
    const btn = document.getElementById('copy-md');
    const source = document.getElementById('post-markdown');
    if (!btn || !source) return;

    let resetTimer;

    const showCopied = () => {
      btn.classList.add('is-copied');
      clearTimeout(resetTimer);
      resetTimer = setTimeout(() => {
        btn.classList.remove('is-copied');
      }, 2000);
    };

    btn.addEventListener('click', async () => {
      const md = source.value;
      try {
        await navigator.clipboard.writeText(md);
        showCopied();
      } catch {
        source.hidden = false;
        source.select();
        try {
          document.execCommand('copy');
          showCopied();
        } finally {
          source.hidden = true;
        }
      }
    });
  })();
</script>
